generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  googleId      String?   @unique @map("google_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  accounts      Account[]
  sessions      Session[]
  vaultMeta     VaultMeta?
  notes         Note[]
  passkeys      UserPasskey[]

  @@map("users")
}

model Account {
  userId             String   @map("user_id")
  type               String
  provider           String
  providerAccountId  String   @map("provider_account_id")
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
  @@map("verification_tokens")
}

model VaultMeta {
  userId             String   @id @map("user_id")
  salt               String
  kdfAlgo            String   @map("kdf_algo")
  kdfParams          Json     @map("kdf_params")
  encryptedVaultKey  String   @map("encrypted_vault_key")
  vaultKeyIv         String   @map("vault_key_iv")
  encryptedCheck     String   @map("encrypted_check")
  checkIv            String   @map("check_iv")
  cryptoVersion      Int      @default(1) @map("crypto_version")
  schemaVersion      Int      @default(1) @map("schema_version")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("vault_meta")
}

model Note {
  id          String    @id
  userId      String    @map("user_id")
  title       String    @default("")
  tags        String[]  @default([])
  bodyPlaintext String? @db.Text @map("body_plaintext")
  ciphertext  String?
  iv          String?
  aad         String?
  isSensitive Boolean   @default(false) @map("is_sensitive")
  lockMode    String    @default("standard") @map("lock_mode")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, deletedAt])
  @@map("notes")
}

model UserPasskey {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  credentialId String   @unique @map("credential_id")
  publicKey    String   @map("public_key")
  counter      Int      @default(0)
  transports   String[] @default([]) @map("transports")
  deviceType   String   @map("device_type")
  backedUp     Boolean  @default(false) @map("backed_up")
  lastUsedAt   DateTime? @map("last_used_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_passkeys")
}
